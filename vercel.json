{
  "version": 2,
  "builds": [
    {
      "src": "etterreel-backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "etterreel-backend/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "etterreel-backend/server.js"
    },
    {
      "src": "/",
      "dest": "etterreel-backend/public/index.html"
    },
    {
      "src": "/([^/]+\\.[^/]+)",
      "dest": "etterreel-backend/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "etterreel-backend/public/index.html"
    }
  ]
}